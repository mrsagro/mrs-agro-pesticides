DATABASE_URL="file:./dev.db"

# JWT Secret (REQUIRED for admin authentication)
JWT_SECRET="your-secure-random-secret-here"

# Admin credentials (REQUIRED for Vercel deployment where SQLite is unavailable)
# Generate password hash: node -e "require('bcryptjs').hashSync('your-password', 12).then(h => console.log(h))"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="$2a$12$..."
